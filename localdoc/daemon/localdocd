import threading
import time

from typing import Sequence
from default import CONFIG_FILEPATH
from configuration import load_configuration
from ipc_purepy import Server


class DocumentationServer(threading.Thread):
    """Hilo que se encarga de iniciar un nuevo servidor para el paquete"""

    def __init__(self, package: str, *args, **kwargs) -> None:
        super().__init__(*args, **kwargs)
        self.package = package
        self.addr = None
        self.port = None

    def run(self) -> None:
        pass


def localdocd() -> int:
    """
    ### Instrucciones de IPC:
    - "close_daemon" | termina el proceso
        - responde "closing daemon"
    - "localdocd_status" | pregunta si el daemon esta vivo
        - responde True | o no hay respuesta si no esta vivo
    - "serve_package": "package_name" | pide servir un paquete
        - responde "package is served in @addr/port@" | si se sirvió
        con éxito
        - o responde "package is already served in @addr/port@" | si ya
        estaba servido
    - "get_served_packages" | pregunta por los paquetes servidos
        - responde {"package_name": (addr, port), ...}
    """
    with open(CONFIG_FILEPATH, "rt") as cfg_file:
        configuration = load_configuration(cfg_file.read())
        if not configuration.socket_filepath.startswith("/tmp/localdoc"):
            return 1

    with Server(configuration.socket_filepath) as server:
        served_documentation: Sequence[DocumentationServer] = []
        while True:
            request = server.wait_connection()
            if request == "close_daemon":
                server.reply("closing daemon")
                server.close_connection()
                # TODO: Aquí debe cerrar todos los threads que esten en ejecución!
                break
            if request == "localdocd_status":
                server.reply(True)
                server.close_connection()
                continue
            if isinstance(request, dict) and "serve_package" in request.keys():
                new_thread = DocumentationServer(
                    package=request["serve_package"]
                )
                generate_thread = True
                for thread in served_documentation:
                    if thread.package == new_thread.package:
                        server.reply(
                            {
                                "package is already served in": (
                                    thread.addr,
                                    thread.port,
                                ),
                            }
                        )
                        server.close_connection()
                        generate_thread = False
                        break
                if generate_thread:
                    new_thread.start()
                    time.sleep(0.5)
                    served_documentation.append(new_thread)
                    server.reply(
                        {
                            "package is served in": (
                                new_thread.addr,
                                new_thread.port,
                            )
                        }
                    )
                    server.close_connection()
                continue
            if request == "get_served_packages":
                served_packages: dict[str, tuple[str, int]] = {}
                for thread in served_documentation:
                    served_packages[thread.package] = (  # type:ignore
                        thread.addr,
                        thread.port,
                    )
                server.reply(served_packages)
                server.close_connection()
                continue
    return 0


if __name__ == "__main__":
    sys.exit(localdocd())
